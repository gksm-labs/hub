<div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-xl shadow-sm border border-slate-100">
  <h2 class="text-3xl font-bold text-slate-900 mb-6 text-center">Prihlásenie</h2>

  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md text-sm mb-6 text-center font-medium">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: 'user@example.com', class: "form-input" %>
    </div>

    <div>
      <%= f.label :password, "Heslo", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
    </div>

    <div class="flex items-center">
      <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary" %>
      <%= f.label :remember_me, "Zapamätať si ma", class: "ml-2 block text-sm text-slate-700" %>
    </div>

    <div class="pt-2">
      <%= f.submit 'Prihlásiť', class: "w-full btn-primary py-2.5 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm">
    <%= render "users/shared/links" %>
  </div>
</div>
