<div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-xl shadow-sm border border-slate-100">
  <h2 class="text-2xl font-bold text-slate-900 mb-6">Zabudnuté heslo?</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
    <%= render "users/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Poslať inštrukcie k obnove", class: "w-full btn-primary py-2.5 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm">
    <%= render "users/shared/links" %>
  </div>
</div>