<div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-xl shadow-sm border border-slate-100">
  <h2 class="text-2xl font-bold text-slate-900 mb-6">Zmena hesla</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
    <%= render "users/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div>
      <%= f.label :password, "Nové heslo", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-input" %>
      <% if @minimum_password_length %>
        <p class="mt-1 text-xs text-slate-500">(Minimálne <%= @minimum_password_length %> znakov)</p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Potvrdiť nové heslo", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Zmeniť heslo", class: "w-full btn-primary py-2.5 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm">
    <%= render "users/shared/links" %>
  </div>
</div>