<div class="flex flex-col gap-2 text-slate-600">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Prihlásiť sa", new_session_path(resource_name), class: "hover:text-blue-600 font-medium" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Zaregistrovať sa", new_registration_path(resource_name), class: "hover:text-blue-600 font-medium" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Zabudli ste heslo?", new_password_path(resource_name), class: "hover:text-blue-600 font-medium" %>
  <% end %>
</div>
