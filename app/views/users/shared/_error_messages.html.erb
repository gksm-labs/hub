<% if resource.errors.any? %>
  <div id="error_explanation" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md mb-5" data-turbo-temporary>
    <h3 class="text-sm font-bold mb-2">
      Nastalo <%= resource.errors.count %> chýb:
    </h3>
    <ul class="list-disc list-inside text-sm ml-2 space-y-1">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
