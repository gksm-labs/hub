<%= form_with(model: [:admin, user], class: "space-y-6 bg-white p-6 sm:p-8 rounded-xl shadow-sm border border-slate-100") do |f| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md mb-6">
      <ul class="list-disc list-inside text-sm">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :first_name, "Meno", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :first_name, class: "form-input w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :last_name, "Priezvisko", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :last_name, class: "form-input w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :email, "E-mail", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.email_field :email, class: "form-input w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
  </div>

  <div>
    <%= f.label :role, "Rola", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "form-input w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
  </div>

  <div class="border-t border-slate-200 pt-6 mt-6">
    <h3 class="text-lg font-medium text-slate-900 mb-2"><%= user.new_record? ? "Heslo" : "Zmena hesla" %></h3>
    <% unless user.new_record? %>
      <p class="text-sm text-slate-500 mb-4">Nevyplňujte, pokiaľ nechcete zmeniť heslo používateľa.</p>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= f.label :password, "Heslo", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password, class: "form-input w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Potvrdenie hesla", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password_confirmation, class: "form-input w-full rounded-md border-slate-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>
    </div>
  </div>

  <div class="pt-4 flex gap-3">
    <%= f.submit "Uložiť", class: "btn-primary cursor-pointer" %>
    <%= link_to "Zrušiť", admin_users_path, class: "btn-secondary inline-flex justify-center rounded-md border border-slate-300 bg-white py-2 px-4 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
  </div>
<% end %>
