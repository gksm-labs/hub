<% if flash.any? %>
  <div class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 pointer-events-none" id="flash-messages">
    <% flash.each do |key, message| %>
      <% next if key.to_s == "alert" && controller_name == "sessions" && action_name == "new" %>

      <div data-controller="toast" class="<%= flash_class_for(key) %>" role="alert">
        <%= flash_icon_for(key) %>
        <span class="flex-1"><%= message %></span>
        <button data-action="click->toast#close" class="text-slate-400 hover:text-slate-600 transition p-1 shrink-0 cursor-pointer">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    <% end %>
  </div>
<% end %>
