<div class="max-w-md mx-auto mt-12 bg-white rounded-2xl shadow-lg border border-slate-100 overflow-hidden">
  <div class="bg-slate-50 border-b border-slate-100 px-6 py-5 text-center">
    <h1 class="text-xl font-bold text-slate-900">Autorizácia aplikácie</h1>
  </div>

  <div class="p-6 sm:p-8">
    <p class="text-slate-600 text-center mb-6">
      Aplikácia <strong class="text-blue-600"><%= @pre_auth.client.name %></strong> požaduje prístup k vášmu účtu.
    </p>

    <% if @pre_auth.scopes.count > 0 %>
      <div class="mb-8 bg-slate-50 rounded-lg p-4">
        <p class="text-sm font-semibold text-slate-700 mb-2">Aplikácia bude môcť:</p>
        <ul class="space-y-2 text-sm text-slate-600">
          <% @pre_auth.scopes.each do |scope| %>
            <li class="flex items-start">
              <svg class="h-5 w-5 text-green-500 mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <%= t scope, scope: [:doorkeeper, :scopes] %>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="flex flex-col gap-3">
      <%= form_tag oauth_authorization_path, method: :post, class: "w-full" do %>
        <%= hidden_field_tag :client_id, @pre_auth.client.uid %>
        <%= hidden_field_tag :redirect_uri, @pre_auth.redirect_uri %>
        <%= hidden_field_tag :state, @pre_auth.state %>
        <%= hidden_field_tag :response_type, @pre_auth.response_type %>
        <%= hidden_field_tag :scope, @pre_auth.scope %>
        <%= hidden_field_tag :code_challenge, @pre_auth.code_challenge %>
        <%= hidden_field_tag :code_challenge_method, @pre_auth.code_challenge_method %>
        <%= submit_tag "Povoliť prístup", class: "w-full btn-primary py-2.5 text-base cursor-pointer" %>
      <% end %>

      <%= form_tag oauth_authorization_path, method: :delete, class: "w-full" do %>
        <%= hidden_field_tag :client_id, @pre_auth.client.uid %>
        <%= hidden_field_tag :redirect_uri, @pre_auth.redirect_uri %>
        <%= hidden_field_tag :state, @pre_auth.state %>
        <%= hidden_field_tag :response_type, @pre_auth.response_type %>
        <%= hidden_field_tag :scope, @pre_auth.scope %>
        <%= hidden_field_tag :code_challenge, @pre_auth.code_challenge %>
        <%= hidden_field_tag :code_challenge_method, @pre_auth.code_challenge_method %>
        <%= submit_tag "Zrušiť", class: "w-full btn-secondary py-2.5 text-base cursor-pointer border-transparent bg-slate-100 hover:bg-slate-200" %>
      <% end %>
    </div>
  </div>
</div>