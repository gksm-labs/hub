<div class="max-w-lg mx-auto mt-12 bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
  <div class="bg-red-50 border-b border-red-100 px-6 py-5">
    <h1 class="text-xl font-bold text-red-800 flex items-center">
      <svg class="w-6 h-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      Nastala chyba autorizácie
