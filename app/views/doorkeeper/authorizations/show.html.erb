<div class="max-w-lg mx-auto mt-12 bg-white rounded-xl shadow-sm border border-slate-100 p-8 text-center">
  <h1 class="text-2xl font-bold text-slate-900 mb-6">Autorizačný kód</h1>

  <p class="text-slate-600 mb-4 text-sm">Skopírujte si tento kód a vložte ho do vašej aplikácie:</p>

  <div class="bg-slate-50 border border-slate-200 p-4 rounded-lg">
    <code id="authorization_code" class="text-lg font-mono text-blue-700 break-all select-all">
      <%= params[:code] %>
    </code>
  </div>
</div>