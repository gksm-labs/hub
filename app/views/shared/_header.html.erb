<header
  class="sticky top-0 z-50 bg-primary text-white shadow-md"
  data-controller="mobile-menu"
  data-action="keydown.esc@window->mobile-menu#close"
>
  <nav class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
      <span class="text-2xl font-bold tracking-tight">Hub</span>
    </a>

    <div class="hidden md:flex items-center gap-4">
      <% if user_signed_in? %>
        <% if current_user.has_permission?(:admin) || current_user.has_permission?(:manage_oauth) || current_user.has_permission?(:manage_users) %>
          <%= link_to "Admin", admin_path, class: "text-white hover:text-white/80 transition-colors font-medium" %>
        <% end %>
        <%= button_to "Odhlásiť sa", destroy_user_session_path, method: :delete, class: "btn-outline inline-flex" %>
      <% else %>
        <a href="<%= new_user_session_path %>" class="btn-red group relative inline-flex overflow-hidden">
          <div class="pointer-events-none absolute inset-y-0 -left-[40%] w-1/3 -skew-x-12 bg-white/30 group-hover:translate-x-[450%] group-hover:transition-transform group-hover:duration-800 group-hover:ease-out"></div>
          <span class="relative z-10">Prihlásiť sa</span>
        </a>
      <% end %>
    </div>

    <button
      type="button"
      data-mobile-menu-target="button"
      data-action="click->mobile-menu#open"
      aria-label="Otvoriť menu"
      aria-expanded="false"
      class="rounded-md border-2 border-white/30 hover:border-white hover:bg-white hover:text-primary font-bold transition-colors duration-100 px-3 py-2 text-sm md:hidden"
    >
      Menu
    </button>

    <div
      data-mobile-menu-target="menu"
      class="pointer-events-none fixed inset-0 bg-primary/95 backdrop-blur-sm opacity-0 transition-opacity duration-100 md:hidden"
    >
      <div
        data-mobile-menu-target="panel"
        class="mx-auto flex h-full max-w-6xl translate-y-6 flex-col px-6 pb-8 pt-6 text-white transition-transform duration-300"
      >
        <div class="flex items-center justify-between">
          <a href="/" class="text-2xl font-bold tracking-tight">Hub</a>
          <button
            type="button"
            data-action="click->mobile-menu#close"
            aria-label="Zavrieť menu"
            class="rounded-md border-2 border-white/30 hover:border-white hover:bg-white hover:text-primary font-bold transition-colors duration-100 px-3 py-2 text-sm md:hidden"
          >
            Zavrieť
          </button>
        </div>

        <div class="mt-auto pt-10 flex flex-col gap-4">
          <% if user_signed_in? %>
            <% if current_user.has_permission?(:admin) || current_user.has_permission?(:manage_oauth) || current_user.has_permission?(:manage_users) %>
              <%= link_to "Admin", admin_path, class: "text-center text-white hover:text-white/80 font-medium py-2" %>
            <% end %>
            <%= button_to "Odhlásiť sa", destroy_user_session_path, method: :delete, class: "btn-outline w-full !py-3 text-base justify-center" %>
          <% else %>
            <a
              href="<%= new_user_session_path %>"
              data-action="click->mobile-menu#close"
              class="btn-red flex w-full !py-3 text-base justify-center"
            >
              Prihlásiť sa
            </a>
          <% end %>
        </div>
      </div>
    </div>
  </nav>
</header>
